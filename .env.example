# Copy this file to .env and fill in your values
# .env is in .gitignore — ye GitHub pe nahi jayega

# Anthropic Claude API key — console.anthropic.com se lo
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Admin panel password — /admin pe ye daaloge
ADMIN_PASSWORD=choose-a-strong-password

# Session secret — koi bhi lamba random string
SECRET_KEY=change-this-to-something-random-in-production
